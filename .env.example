# ── Copy this file to .env and fill in your values ──────────────────────────

# Ollama (local, no API key needed — install from https://ollama.com/)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b         # or phi3, llama3.2, gemma3:4b

# Text embedding model (downloaded automatically from HuggingFace)
TEXT_EMBED_MODEL=all-MiniLM-L6-v2

# CLIP model for multimodal image+text embeddings
CLIP_MODEL=openai/clip-vit-base-patch32

# Cross-encoder reranker model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# FAISS index persistence directory (relative to backend/)
FAISS_INDEX_DIR=faiss_store

# Retrieval settings
RETRIEVE_TOP_K=10
RERANK_TOP_N=3
